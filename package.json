{
  "name": "@codeplaydata/datasus",
  "version": "2.0.0",
  "main": "index.js",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:core": "npm run build -w @codeplaydata/datasus-core",
    "build:linkage": "npm run build -w @codeplaydata/datasus-linkage",
    "build:app": "tsc -b --force tsconfig.app.json",

    "siasus:main": "npm run build:app && node --max-old-space-size=4096 ./dist/app/siasus/main.js",
    "siasus:linkage": "npm run build:app && node --max-old-space-size=4096 ./dist/app/siasus/linkage.js",
    "sinan:main": "npm run build:app && node --max-old-space-size=4096 ./dist/app/sinan/main.js",
    "sihsus:main": "npm run build:app && node --max-old-space-size=4096 ./dist/app/sihsus/main.js",
    "sim:main": "npm run build:app && node --max-old-space-size=4096 ./dist/app/sim/main.js",

    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "npx tsx --test test/unit/**/*.test.ts",
    "pretest:integration": "npx tsx test/integration/packages/core/fixtures/download_fixture.ts",
    "test:integration": "npx tsx --test test/integration/**/*.test.ts",
    "test:e2e": "npx tsx --test-timeout 120000 --test test/e2e/**/*.test.ts",
    
    "publish": "npm publish --workspaces --access=public",
    "publish:core": "npm publish -w @codeplaydata/datasus-core --access=public",
    "publish:linkage": "npm publish -w @codeplaydata/datasus-linkage --access=public"
  },
  "keywords": [
    "DATASUS",
    "dbc",
    "health"
  ],
  "author": "Pedro Paulo dos Santos (dr2p) - https://github.com/dr2pedro",
  "license": "Apache-2.0",
  "description": "This application decompress the datasus micro data and serve as a gateway class.",
  "devDependencies": {
    "@types/node": "^22.20.1",
    "mongodb": "^7.0.0",
    "typescript": "^5.8.3"
  }
}
